OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Shopify Theme Audit Agent

# Fallback (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# For OpenRouter, model format is typically provider/model
OPENAI_MODEL=openai/gpt-4.1-mini

# Optional: Google Docs auto-create (service account, recommended for long-term stability)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHARE_WITH_EMAIL=
GOOGLE_AUTH_MODE=auto

# Optional: Google Docs auto-create (OAuth user, preferred when
# service accounts fail with storageQuotaExceeded).
# Note: if OAuth app is in Testing mode, refresh tokens can expire in 7 days.
# To avoid weekly token rotation, either:
# 1) use service-account mode, or
# 2) publish OAuth consent screen to Production and reconnect.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
 