OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Shopify Theme Audit Agent

# Fallback (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# For OpenRouter, model format is typically provider/model
OPENAI_MODEL=openai/gpt-4.1-mini

# Optional: Google Docs auto-create (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SHARE_WITH_EMAIL=

# Optional: Google Docs auto-create (OAuth user, preferred when
# service accounts fail with storageQuotaExceeded)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
